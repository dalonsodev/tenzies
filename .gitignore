# 1. Dependencies (Safeguard for environments without a global gitignore)
node_modules/
.pnpm-store/

# 2. Production & Build Outputs
dist/
dist-ssr/
build/
coverage/
*.local

# 3. Environment Variables (CRITICAL: Never commit credentials or API keys)
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# 4. Package Manager Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 5. OS / System Files
.DS_Store
Thumbs.db
.fseventsd

# Tooling and TypeScript Caches
.tsbuildinfo
.eslintcache
.prettiercache
.vite
